# Copy to .env in the repo root and fill in values.
# ENVIRONMENT has no default in app/config.py -- the app refuses to start
# without it being set explicitly.

ENVIRONMENT=development
APP_NAME=ragp
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Storage (Stage 2). Optional for the bare API skeleton; REQUIRED for
# ingestion and any DB/Redis-backed component -- those fail loudly at the
# point of use if unset. Free-tier examples: Neon/Supabase for Postgres,
# Upstash for Redis.
DATABASE_URL=postgresql://user:password@host:5432/ragp
REDIS_URL=redis://default:password@host:6379/0
INDEX_ROOT=indexes
